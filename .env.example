# 医疗RAG知识库 - 环境配置
# 复制此文件为 .env 并填入真实密钥

# MinerU配置
PARSER=mineru
PARSE_METHOD=auto
OUTPUT_DIR=./output

# 缓存目录
CACHE_DIR=./cache

# 模型配置
TEXT_MODEL=DeepSeek-V4-Pro
VISION_MODEL=Kimi-K2.6
AGENT_MODEL=GLM-5.1

# 讯飞 API (GLM-5.1, LightRAG 实体提取主引擎)
XUNFEI_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
XUNFEI_API_KEY=your_key_here

# 百度千帆 API (DeepSeek-V4-Flash/Pro)
BAIDU_BASE_URL=https://qianfan.baidubce.com/v2/coding
BAIDU_API_KEY=your_key_here

# Moonshot API (VLM 图表理解)
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=your_key_here

# OpenAI 兼容 API
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
