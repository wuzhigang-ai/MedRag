<node id="Log-Rank P=0.97">
  <data key="d0">Log-Rank P=0.97</data>
  <data key="d1">data</data>
  <data key="d2">Log-Rank P=0.97 is the statistical test result indicating no significant difference in survival between the Impella and IABP groups.</data>
  <data key="d3">chunk-ff0702c16a40074abed0254fa2987a4d</data>
  <data key="d4">seyfarth2008.pdf</data>
  <data key="d5">1780045976</data>
