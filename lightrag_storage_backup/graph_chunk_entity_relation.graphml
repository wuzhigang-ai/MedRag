  <data key="d0">30-Day Survival Curves</data>
  <data key="d1">data</data>
  <data key="d2">Survival curves comparing Impella patients versus intra-aortic balloon pump patients over 30 days.</data>
  <data key="d3">chunk-ca971059e15553c9f065f9d48ca96130</data>
  <data key="d4">mineru_seyfarth2008.pdf</data>
  <data key="d5">1779836746</data>
  <data key="d6"></data>
</node>
<node id="Hemodynamic Derangement">
  <data key="d0">Hemodynamic Derangement</data>
  <data key="d1">concept</data>
  <data key="d2">A disturbance in blood circulation that, when reversed, leads to improved organ dysfunction scores.</data>
  <data key="d3">chunk-ca971059e15553c9f065f9d48ca96130</data>
  <data key="d4">mineru_seyfarth2008.pdf</data>
  <data key="d5">1779836747</data>
  <data key="d6"></data>
</node>
