</node>
<node id="Days After Randomization">
  <data key="d0">Days After Randomization</data>
  <data key="d1">concept</data>
  <data key="d2">Days After Randomization is the time variable on the x-axis of the survival curves, ranging from 0 to 30 days.</data>
  <data key="d3">chunk-ff0702c16a40074abed0254fa2987a4d</data>
  <data key="d4">seyfarth2008.pdf</data>
  <data key="d5">1780045976</data>
