  <data key="d5">1779836747</data>
  <data key="d6"></data>
</node>
<node id="Impella">
  <data key="d0">Impella</data>
  <data key="d1">artifact</data>
  <data key="d2">Impella is a catheter-based, miniaturized rotary blood pump (LVAD) used for hemodynamic support, which provides easy percutaneous access and was associated with shorter mechanical ventilation time, higher hemolysis, and more blood product administration compared to IABP.</data>
  <data key="d3">chunk-7d070016888b87e5d8407655292c6a98</data>
  <data key="d4">mineru_seyfarth2008.pdf</data>
  <data key="d5">1779836747</data>
  <data key="d6"></data>
