  <data key="d0">Acute Myocardial Infarction</data>
  <data key="d1">event</data>
  <data key="d2">Acute myocardial infarction is a medical event causing cardiogenic shock, studied in the clinical trial.</data>
  <data key="d3">chunk-cd12a4d42988a0cbef608f813b7db575</data>
