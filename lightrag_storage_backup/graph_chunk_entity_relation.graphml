  <data key="d0">Charles P. Venditti</data>
  <data key="d1">person</data>
  <data key="d2">Charles P. Venditti is an MD, PhD and a contributing author of the study on chronic kidney disease in propionic acidemia.</data>
  <data key="d3">chunk-94e6c2d3a322064c0bedf6b639e576b4</data>
