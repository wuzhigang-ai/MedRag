  <data key="d0">Dai Qing</data>
  <data key="d1">person</data>
  <data key="d2">Dai Qing is the drafter and a core expert from Peking Union Medical College Hospital.</data>
  <data key="d3">chunk-8cbe0f288d4aaea04ac19b92c24f1266</data>
  <data key="d4">子宫内膜异位症超声评估中国专家共识.pdf</data>
  <data key="d5">1779837099</data>
  <data key="d6"></data>
</node>
