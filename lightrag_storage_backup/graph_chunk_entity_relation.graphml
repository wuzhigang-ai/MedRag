  <data key="d0">Acute Limb Ischemia</data>
  <data key="d1">event</data>
  <data key="d2">Acute limb ischemia is an adverse event that occurred in 1 case requiring surgery after device explantation in a patient assigned to the Impella group.</data>
  <data key="d3">chunk-7d070016888b87e5d8407655292c6a98</data>
  <data key="d4">mineru_seyfarth2008.pdf</data>
  <data key="d5">1779836747</data>
