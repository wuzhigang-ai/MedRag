<node id="Survival Probability">
  <data key="d0">Survival Probability</data>
  <data key="d1">data</data>
  <data key="d2">Survival Probability is a statistical measure shown on the y-axis of the Kaplan-Meier curves, comparing outcomes between Impella and IABP groups.</data>
  <data key="d3">chunk-ff0702c16a40074abed0254fa2987a4d</data>
  <data key="d4">seyfarth2008.pdf</data>
