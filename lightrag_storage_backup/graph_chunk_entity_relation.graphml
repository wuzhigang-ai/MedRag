  <data key="d0">Deutsches Herzzentrum München</data>
  <data key="d1">organization</data>
  <data key="d2">A heart center located in Munich, Germany, affiliated with the corresponding author.</data>
  <data key="d3">chunk-ca971059e15553c9f065f9d48ca96130</data>
  <data key="d4">mineru_seyfarth2008.pdf</data>
  <data key="d5">1779836746</data>
  <data key="d6"></data>
</node>
<node id="Melchior Seyfarth">
  <data key="d0">Melchior Seyfarth</data>
  <data key="d1">person</data>
  <data key="d2">The corresponding author of the study, affiliated with Deutsches Herzzentrum München.&lt;SEP&gt;A medical doctor and one of the primary authors of the study.</data>
  <data key="d3">chunk-ca971059e15553c9f065f9d48ca96130&lt;SEP&gt;chunk-40ef920a3d882cbe9feb69d377f883e2</data>
  <data key="d4">mineru_seyfarth2008.pdf</data>
  <data key="d5">1779836746</data>
