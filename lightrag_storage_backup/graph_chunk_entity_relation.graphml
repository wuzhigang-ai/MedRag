  <data key="d0">Glomerular Sclerosis</data>
  <data key="d1">concept</data>
  <data key="d2">Glomerular Sclerosis is a pathological condition involving scarring of the glomeruli in the kidney.</data>
  <data key="d3">chunk-518d22241c7304c17fbdf836ee4ebc04</data>
