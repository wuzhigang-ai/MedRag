</node>
<node id="CPS-1">
  <data key="d0">CPS-1</data>
  <data key="d1">concept</data>
  <data key="d2">An enzyme exhibiting significant activity in the liver homogenate; its deficiency was present in a 2-wk-old infant and a 20-mo-old boy.&lt;SEP&gt;Carbamoyl phosphate synthetase I, a urea cycle enzyme whose deficiency is treated via liver transplantation; also referred to as CPS-I.</data>
  <data key="d3">chunk-d68295a29209c79daf4f790b7e23aa59&lt;SEP&gt;chunk-f1325880215e7364fb40c4d244be7ba9</data>
  <data key="d4">mineru_todo1992.pdf&lt;SEP&gt;todo1992.pdf</data>
