</node>
<node id="30 Days">
  <data key="d0">30 Days</data>
  <data key="d1">event</data>
  <data key="d2">30 Days is the follow-up time point at which MODS and SOFA scores were measured and survival was assessed.&lt;SEP&gt;30 Days is the endpoint time point in the survival analysis following randomization.</data>
  <data key="d3">chunk-ff0702c16a40074abed0254fa2987a4d&lt;SEP&gt;chunk-c33f31a24de4f3032f5ab5311fd13365</data>
  <data key="d4">seyfarth2008.pdf</data>
  <data key="d5">1780045976</data>
