  <data key="d4">mineru_seyfarth2008.pdf</data>
  <data key="d5">1779836747</data>
  <data key="d6"></data>
</node>
<node id="CS">
  <data key="d0">CS</data>
  <data key="d1">event</data>
  <data key="d2">CS (Cardiogenic Shock) is the condition caused by AMI for which patients were treated using Impella or IABP.</data>
